# ============================================================
# .env.example — Quizoi Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ─── Supabase Database ────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → Database → Connection String
# Use the "Session Pooler" URL (port 6543) — required for serverless/Railway.
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# IMPORTANT: If your password contains @, replace it with %40
# Example: Ayman123@@ becomes Ayman123%40%40
DATABASE_URL=postgresql://postgres.hhbbulecppmtmdmxciku:Ayman123%40%40@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ─── Supabase API Keys ────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
# ANON key: safe to expose to the browser (used for public read operations)
# SERVICE ROLE key: NEVER expose to the browser — server-side only
SUPABASE_URL=https://hhbbulecppmtmdmxciku.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhoYmJ1bGVjcHBtdG1kbXhjaWt1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU2NTgzNzYsImV4cCI6MjA5MTIzNDM3Nn0.Yoaj0d0NJs_gKx1oHHFpPPIzbqFmEHDnk6SCym6jXQI
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhoYmJ1bGVjcHBtdG1kbXhjaWt1Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NTY1ODM3NiwiZXhwIjoyMDkxMjM0Mzc2fQ.uE71q05SACoJlioXJqxfQB5tYNsxHQQu3LczwFj6sPo

# ─── Admin Authentication ─────────────────────────────────────────────────────
# Secret header value required for all /api/admin/* routes.
# Generate a strong random string: openssl rand -base64 32
ADMIN_SECRET=change-this-to-a-strong-random-secret

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

